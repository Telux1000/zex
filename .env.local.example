# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI
OPENAI_API_KEY=sk-...

# Stripe (Connect + customer invoice card payments — not platform SaaS subscription)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: set to "true" to enable Stripe Connect onboarding/sync API routes (merchant invoice payouts).
# STRIPE_CONNECT_ENABLED=true

# Platform SaaS subscription (Flutterwave / Paystack — server redirect checkout; webhooks /api/webhooks/flutterwave, /api/webhooks/paystack)
FLUTTERWAVE_SECRET_KEY=FLWSECK_...
# Optional: Flutterwave payment plan ids per tier (see plan-provider-refs)
# FLUTTERWAVE_PAYMENT_PLAN_GROWTH_MONTHLY=
PAYSTACK_SECRET_KEY=sk_live_...
# Optional: Paystack plan codes (see plan-provider-refs)
# PAYSTACK_PLAN_GROWTH_MONTHLY=
# Stripe — optional future provider
# Stripe SaaS mode reuses STRIPE_SECRET_KEY and STRIPE_WEBHOOK_SECRET above.
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_PROFESSIONAL_MONTHLY=
STRIPE_PRICE_ENTERPRISE_MONTHLY=
STRIPE_PRICE_GROWTH_YEARLY=
STRIPE_PRICE_PROFESSIONAL_YEARLY=
STRIPE_PRICE_ENTERPRISE_YEARLY=

# Public marketing / trial lock price ids (e.g. from your catalog).
NEXT_PUBLIC_CATALOG_PRICE_GROWTH_MONTHLY=
NEXT_PUBLIC_CATALOG_PRICE_PROFESSIONAL_MONTHLY=
NEXT_PUBLIC_CATALOG_PRICE_ENTERPRISE_MONTHLY=
NEXT_PUBLIC_CATALOG_PRICE_GROWTH_YEARLY=
NEXT_PUBLIC_CATALOG_PRICE_PROFESSIONAL_YEARLY=
NEXT_PUBLIC_CATALOG_PRICE_ENTERPRISE_YEARLY=
# Optional: server-only. First SaaS checkout provider: paystack | flutterwave (default if unset/invalid). Restart dev server after change.
# BILLING_SAAS_PRIMARY=paystack
# Optional: generic billing webhook for non-Stripe processors (header x-billing-webhook-secret)
# BILLING_WEBHOOK_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production deployments MUST set:
# NEXT_PUBLIC_APP_URL=https://www.zenzex.com
# STRIPE_CONNECT_RETURN_URL=https://www.zenzex.com/settings?section=payment&stripe=return
# STRIPE_CONNECT_REFRESH_URL=https://www.zenzex.com/settings?section=payment&stripe=refresh

# Postmark — required for ANY outbound mail (waitlist confirmation + admin waitlist invite use these + HTML in code; no extra template env vars).
# Postmark → Servers → API Tokens → Server API token
POSTMARK_SERVER_TOKEN=
# Must be a verified sender signature / domain in Postmark (e.g. hello@yourdomain.com)
POSTMARK_FROM_EMAIL=
# Optional
# POSTMARK_REPLY_TO=support@yourdomain.com
# POSTMARK_MESSAGE_STREAM_OUTBOUND=outbound

# Postmark templates (aliases or numeric TemplateId). Not used for waitlist signup/invite — those use POSTMARK_* above only.
# When set, team invites use generateLink + Postmark (no Supabase Auth invite email).
POSTMARK_TEMPLATE_USER_INVITATION=your_template_id_or_alias

# Self-service forgot password (login page). Copy postmark/forgot-password.html into Postmark and set alias or ID.
POSTMARK_TEMPLATE_FORGOT_PASSWORD=forgot-password

# Team + admin “send password reset” (Supabase recovery link). Use the same Postmark template as your standard user reset email; merge fields: reset_url, expiry_minutes, year, recipient_email (same shape as forgot-password).
POSTMARK_TEMPLATE_USER_PASSWORD_RESET=user-password-reset

# Required on the DEPLOYED host (Vercel etc.) or Supabase keeps sending its own "Confirm your signup" email.
# Supabase Dashboard → Authentication → Hooks → Send Email → URL https://YOUR_DOMAIN/api/auth/supabase-email-hook
SEND_EMAIL_HOOK_SECRET=v1,whsec_paste_from_supabase_dashboard
POSTMARK_TEMPLATE_SIGNUP_CONFIRM=signup-confirm
# Supabase → Authentication → URL Configuration → Redirect URLs must include:
#   {NEXT_PUBLIC_APP_URL}/auth/callback
# Email confirmation uses PKCE (?code= on that URL). Do not use /login as the email redirect target.

# Guided onboarding “setup complete” welcome (optional). Alias or numeric TemplateId; falls back to built-in HTML if unset.
# Copy postmark/welcome_message.html into Postmark; suggested alias: welcome_message
# Template subject: You're all set with {{app_name}} 🎉
# Merge fields: first_name, business_name, dashboard_url, support_email, app_name, year
POSTMARK_TEMPLATE_WELCOME_SETUP_COMPLETE=welcome_message

# Shown in welcome email (defaults to Zenzex). Footer support address falls back from SUPPORT_EMAIL → POSTMARK_REPLY_TO → POSTMARK_FROM_EMAIL.
NEXT_PUBLIC_APP_NAME=Zenzex
# SUPPORT_EMAIL=you@yourdomain.com

# Customer payment reminders (auto reminders, cron, manual “send reminder”, scheduled digest). Copy postmark/payment-reminder.html into Postmark.
# Set the template Subject in Postmark to: {{subject}}
# Merge fields: subject, reminder_message (HTML, triple-mustache in template as {{{reminder_message}}}),
#   customer_name, business_name, invoice_number, amount_due, due_date, payment_link, support_email, tone;
#   legacy: invoiceNumber, companyName, dueDate, customerName, amountDue, currency, paymentUrl, paymentLinkText, hasPaymentUrl
# Point POSTMARK_TEMPLATE_OVERDUE_REMINDER to the same alias as payment reminder if you previously used a separate template.
POSTMARK_TEMPLATE_PAYMENT_REMINDER=payment-reminder

# Onboarding follow-up processor (optional). Cron: POST /api/admin/onboarding/follow-ups/process with Authorization: Bearer <secret>.
# When unset, only signed-in internal admins can trigger the same route (e.g. Admin → Accounts → Onboarding “Run follow-up processor”).
# ONBOARDING_FOLLOW_UPS_CRON_SECRET=...

# “Email payment link” from Stripe flow (distinct from payment reminder). Optional separate template.
# POSTMARK_TEMPLATE_PAYMENT_LINK=payment-link

# Waitlist — optional geo banner on Billing (owner, trialing or payment required). ISO2 codes, comma-separated (e.g. US,CA). Empty = off.
# NEXT_PUBLIC_WAITLIST_GEO_PROMPT_COUNTRIES=US,CA
